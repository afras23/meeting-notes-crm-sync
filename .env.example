# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1
DOCS_ENABLED=true
# Optional: if host ports conflict (docker compose)
# API_PORT=8001
# DB_PORT=5433

# Database (async SQLAlchemy)
# Local SQLite:
DATABASE_URL=sqlite+aiosqlite:///./app.db
# Docker Compose (Postgres service):
# DATABASE_URL=postgresql+asyncpg://appuser:apppass@db:5432/appdb

# AI
AI_PROVIDER=mock
AI_MODEL=mock-llm
MAX_DAILY_COST_USD=5.0
AI_TIMEOUT_SECONDS=30
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_RECOVERY_SECONDS=30

# Notifications
SLACK_WEBHOOK_URL=
EMAIL_FROM=no-reply@example.com
EMAIL_TO=

# CRM
CRM_PROVIDER=hubspot_mock
CRM_MAPPING_CRM=hubspot
